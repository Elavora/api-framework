{
  "name": "elavora/api-framework",
  "description": "Nucleo HTTP modular do framework Elavora",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": ">=8.1",
    "ext-json": "*"
  },
  "autoload": {
    "psr-4": {
      "Elavora\\Api\\Framework\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Elavora\\Api\\Framework\\Tests\\": "tests/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5 || ^11.0 || ^12.0"
  },
  "scripts": {
    "lint": "find src tests -name '*.php' -print0 | xargs -0 -n1 php -l",
    "test": "phpunit -c phpunit.xml",
    "check": [
      "@lint",
      "@test"
    ]
  },
  "config": {
    "sort-packages": true
  },
  "extra": {
    "branch-alias": {
      "dev-main": "1.0-dev"
    }
  }
}
